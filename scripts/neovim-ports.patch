+const normalizeOrgPreviewText = (text: string | null | undefined, level?: number | null): string => {
+  const starsToTrim = Math.max((level ?? 1) - 1, 0)
+  return (text ?? '')
+    .split('\n')
+    .map((line) => {
+      const match = line.match(/^\s*(\*+)(\s+)/)
+      if (!match || match[1].length <= starsToTrim) {
+        return line
+      }
+
+      return `${match[1].slice(starsToTrim)}${match[2]}${line.slice(match[0].length)}`
+    })
+    .join('\n')
+}
